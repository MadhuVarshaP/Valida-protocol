# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build artifacts ───────────────────────────────────────────────────────────
build/
dist/
out/

# Solana / Anchor — compiled binaries and incremental build cache
# Regenerate with: anchor build
solana/target/

# Next.js
.next/
frontend/.next/

# ZK trusted setup output (regenerate: bash scripts/setup-zk.sh)
frontend/public/circuits/

# ── Environment secrets ───────────────────────────────────────────────────────
# NEVER commit .env files — use .env.example as the template
.env
.env.local
.env.*.local
*.env

# ── Solana keypairs ───────────────────────────────────────────────────────────
# Wallet keypairs must never be committed
*.json.key
id.json
solana-keypair.json
solana/target/deploy/*-keypair.json

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
coverage/
.vercel

# ── Devnet test keypairs (private keys — never commit) ────────────────────────
.test-auditor.json
**/.test-auditor.json
