NODE_ENV=development
PORT=3001

# Optional: if set, an admin user is created/updated at startup (for testing)
# ADMIN_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# Optional fallback if contract owner/admin getter is unavailable via ABI selectors.
# CONTRACT_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/bpms

# Base Sepolia (chain ID 84532) - use your deployed contract address
RPC_URL=https://base-sepolia.drpc.org
CONTRACT_ADDRESS=0xYourContractAddress

# Use PINATA_JWT, or PINATA_API_KEY + PINATA_SECRET_KEY. Placeholder values enable mock IPFS for tests.
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
# PINATA_JWT=your_jwt_token

IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
API_BASE_URL=http://localhost:3001
# Comma-separated list of allowed frontend origins for CORS (use * only for local debugging).
# Example: CORS_ALLOWED_ORIGINS=https://bpms-frontend.vercel.app,http://localhost:3000
# CORS_ALLOWED_ORIGINS=
AUTH_BYPASS=false
AUTH_MESSAGE=BPMS wallet verification

# Optional: enable backend read-only event listener for PatchInstalled.
ENABLE_CONTRACT_EVENT_SYNC=false

# Device Agent signer (only needed when running backend/device-agent/patchAgent.js)
# Keep this private and never commit real keys.
DEVICE_WALLET_ADDRESS=0xYourDeviceWallet
DEVICE_PRIVATE_KEY=0xyour_device_private_key