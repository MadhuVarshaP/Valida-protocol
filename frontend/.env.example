# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# App Configuration
NEXT_PUBLIC_APP_NAME=BPMS

# WalletConnect Cloud project ID (required for RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# BPMS contract address for frontend calls
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress

# Block explorer base URL
NEXT_PUBLIC_RPC_URL=https://rpc-testnet.iopn.io
NEXT_PUBLIC_EXPLORER_BASE_URL=https://explorer-testnet.iopn.io

# ── Zeno Phase 1: Vulnerability Portal ───────────────────────────────────────
# ZenoVulnerability contract address (from deployment.json after running deploy.js)
NEXT_PUBLIC_VULN_CONTRACT_ADDRESS=0xYourVulnContractAddress

# ── Zeno Phase 2: Staking + Escrow ───────────────────────────────────────────
# ZenoEscrow contract address (from deployment.json after running deploy.js)
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0xYourEscrowContractAddress

# ── Zeno Phase 3: Commitment Anti-Forgery + IPFS ─────────────────────────────
# Pinata JWT for IPFS uploads (keep server-side in production)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token

# Symmetric key for AES-GCM encryption of vulnerability details before IPFS upload
# In production: replace with asymmetric encryption (admin RSA/EC public key)
NEXT_PUBLIC_REVEAL_ENCRYPTION_KEY=change-this-to-a-strong-random-secret

# IPFS gateway for fetching encrypted content
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Zeno Phase 4: ZK Proof Integration ───────────────────────────────────────
# ZenoZKVerifier contract address (from deployment.json after running deploy.js + setup-zk.sh)
NEXT_PUBLIC_ZK_VERIFIER_ADDRESS=0xYourZKVerifierContractAddress
